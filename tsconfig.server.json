{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    /* Project references */
    "composite": true,
    "declarationMap": true,

    /* Output */
    "outDir": "dist/server",
    "rootDir": "src/server",

    /* Module strictness */
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "erasableSyntaxOnly": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/server/**/*"]
}
